{
  "name": "@korchasa/flowai-workflow",
  "version": "0.5.0",
  "license": "MIT",
  "exports": "./cli.ts",
  "imports": {
    "@korchasa/ai-ide-cli": "jsr:@korchasa/ai-ide-cli@^0.5.6",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "@std/semver": "jsr:@std/semver@^1.0.0",
    "@std/cli": "jsr:@std/cli@^1.0.0",
    "@std/fs": "jsr:@std/fs@^1.0.0"
  },
  "tasks": {
    "check": "deno run -A scripts/check.ts",
    "test": "deno test -A --no-check --ignore=.claude/worktrees,.flowai-workflow/*/runs",
    "run": "deno run -A --no-check cli.ts run .flowai-workflow/github-inbox",
    "loop": "deno run -A --no-check scripts/self-runner.ts",
    "dashboard": "deno run --allow-read --allow-write scripts/generate-dashboard.ts",
    "compile": "deno run -A scripts/compile.ts",
    "release": "deno run -A npm:standard-version --skip.tag",
    "fmt": "deno fmt"
  },
  "fmt": {
    "proseWrap": "preserve",
    "exclude": [
      "**/*.md",
      ".*/**/*.md",
      "init/templates/"
    ]
  },
  "lint": {
    "exclude": [
      ".claude/worktrees/",
      ".flowai-workflow/*/agents/",
      "init/templates/"
    ]
  },
  "publish": {
    "include": [
      "./",
      "./deno.json",
      "./README.md"
    ],
    "exclude": [
      "**/*_test.ts",
      ".claude/**",
      ".devcontainer/**",
      ".flowai-workflow/**",
      ".github/**",
      "documents/**",
      "scripts/**",
      "AGENTS.md",
      "CLAUDE.md",
      "CHANGELOG.md",
      ".versionrc.json",
      ".gitignore",
      ".gitattributes",
      "deno.lock"
    ]
  }
}
