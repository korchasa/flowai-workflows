{
  "imports": {
    "@std/assert": "./vendor/assert.ts",
    "@std/yaml": "./vendor/yaml.ts"
  },
  "tasks": {
    "check": "deno run -A scripts/check.ts",
    "test": "deno test -A --no-check --ignore=.claude/",
    "test:lib": "deno test -A --no-check .auto-flow/scripts/lib_test.ts",
    "run": "deno run -A --no-check engine/cli.ts --config .auto-flow/pipeline.yaml",
    "loop": "deno run -A --no-check scripts/self_runner.ts",
    "test:engine": "deno test -A --no-check engine/",
    "fmt": "deno fmt",
    "loop-in-claude": "deno run -A --no-check scripts/loop_in_claude.ts",
    "dev": "echo 'No dev server for pipeline project'",
    "prod": "echo 'No prod mode for pipeline project'",
    "dashboard": "deno run --allow-read --allow-write scripts/generate-dashboard.ts",
    "compile": "deno run -A scripts/compile.ts"
  },
  "fmt": {
    "proseWrap": "preserve",
    "exclude": ["**/*.md", ".*/**/*.md"]
  },
  "lint": {
    "exclude": [".claude/", ".auto-flow/agents/"]
  }
}
