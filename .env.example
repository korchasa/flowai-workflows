# Copy to .env and fill values. .env is gitignored.

# Telegram HITL transport (used by .flowai-workflow/scripts/hitl-*.sh).
# 1. Create a bot via @BotFather → copy the HTTP API token here.
# 2. Send any message to the bot from your Telegram account, then open
#    https://api.telegram.org/bot<TOKEN>/getUpdates and copy chat.id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
