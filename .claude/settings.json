{
  "permissions": {
    "allow": [
      "Read(//Users/korchasa/.claude/skills/flow-init/assets/**)",
      "Read(//Users/korchasa/www/tools/flow/framework/skills/flow-init/assets/**)",
      "Read(//Users/korchasa/.claude/skills/flow-init/**)",
      "Read(//Users/korchasa/www/tools/flow/framework/skills/flow-init/**)",
      "Bash(deno task check)",
      "Bash(deno fmt)",
      "Read(//Users/korchasa/.claude/skills/flow-engineer-hook/**)",
      "Read(//Users/korchasa/www/tools/flow/framework/skills/flow-engineer-hook/**)",
      "WebSearch",
      "Read(//Users/korchasa/.claude/**)",
      "Bash(deno run -A scripts/fmt.ts)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/guard-deno-direct.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "deno run -A .claude/scripts/flowai-test-before-commit/run.ts",
            "timeout": 600
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "deno run -A .claude/scripts/flowai-lint-on-write/run.ts",
            "timeout": 30
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "deno run -A .claude/scripts/flowai-skill-structure-validate/run.ts",
            "timeout": 30
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "deno run -A .claude/scripts/flowai-mermaid-validate/run.ts",
            "timeout": 30
          }
        ],
        "matcher": "Write|Edit"
      }
    ]
  }
}